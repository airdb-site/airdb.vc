---
import Base from "../layouts/Base.astro";
---

<Base title="页面不存在 · AirDB Ventures">
  <main id="main">
    <section class="contact" style="min-height: 100svh; display: grid; place-items: center;">
      <div class="wrap">
        <div class="contact-seal" aria-hidden="true">迷</div>
        <h2>这条路不通。</h2>
        <p class="contact-hint">你要找的页面不存在，或已被移走。</p>
        <a class="btn btn-primary" href="/" style="margin-top: 36px;">回到首页</a>
      </div>
    </section>
  </main>
</Base>
