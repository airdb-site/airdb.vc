---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AirDB Ventures · 投资一个人的公司 | 海南三亚",
  description = "AirDB Ventures 是一家立足海南三亚的早期基金，专注投资中国大陆一人公司（OPC）与「一带一路」沿线国家的超级个体企业。",
} = Astro.props;

const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "AirDB Ventures",
  url: "https://airdb.vc",
  email: "hello@airdb.vc",
  description,
  address: {
    "@type": "PostalAddress",
    addressLocality: "三亚",
    addressRegion: "海南",
    addressCountry: "CN",
  },
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={Astro.url} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AirDB Ventures" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="https://airdb.vc/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="theme-color" content="#f6f1e6" />
    <script is:inline>document.documentElement.classList.add("js");</script>
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} is:inline />
  </head>
  <body>
    <a class="skip-link" href="#main">跳到正文</a>
    <slot />
    <script>
      const head = document.querySelector(".site-head");
      const onScroll = () => head?.classList.toggle("scrolled", window.scrollY > 24);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      const strip = document.querySelector(".route-strip");
      if (strip) {
        new IntersectionObserver(([e]) =>
          strip.classList.toggle("paused", !e.isIntersecting)
        ).observe(strip);
      }
    </script>
  </body>
</html>
